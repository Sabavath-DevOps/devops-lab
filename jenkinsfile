pipeline {
  agent any

  stages {

    stage('Clone Code') {
      steps {
        sh 'echo Cloning code...'
      }
    }

    stage('Build') {
      steps {
        sh 'echo Building project...'
      }
    }

    stage('Test') {
      steps {
        sh 'echo Running tests...'
      }
    }

    stage('Deploy') {
      steps {
        sh 'echo Deploying application...'
      }
    }

  }
}
